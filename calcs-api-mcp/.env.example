# Calcs API MCP Server Configuration

# ── Calcs API Authentication (one of these is required) ──

# Option 1 (recommended for deployed services): Auth0 password grant
# The server will fetch and auto-refresh bearer tokens from Auth0
AUTH0_PASSWORD=your_auth0_password_here

# Option 2 (for local development): Static bearer token
# CALCS_API_TOKEN=your_bearer_token_here

# ── API Configuration ──

# Optional: Base URL for the Calcs API (defaults to staging)
CALCS_API_BASE_URL=https://staging-app.marketdial.dev/calcs

# Optional: Default client identifier to use when not specified in tool calls
CALCS_DEFAULT_CLIENT=your_client_name_here

# ── Google OAuth (optional, for HTTP/SSE transports) ──

# GOOGLE_CLIENT_ID=your_google_oauth_client_id
# GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# MCP_BASE_URL=http://localhost:8080
